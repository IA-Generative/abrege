# ────────────────────────────────────────────────────────────────────────────
# LLM / OpenAI-compatible API  (REQUIRED)
# ────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_API_MODEL=qwen2.5
OPENAI_VLM_MODEL_NAME=mistral-small-3.1-24b-instruct-2503  # Used when OCR_SERVICE_LLM=LLM
MAX_CONTEXT_SIZE=128000
TOKENIZER_MODEL_NAME=gpt-4
HF_TOKEN=   # Required to download the tokenizer from HuggingFace

# ────────────────────────────────────────────────────────────────────────────
# Database  (REQUIRED)
# ────────────────────────────────────────────────────────────────────────────
# In Docker Compose use the service name as host, e.g. @db:5432
DATABASE_URL=postgresql://postgres:secret@localhost:5432/example_db

# ────────────────────────────────────────────────────────────────────────────
# Redis / Celery broker  (REQUIRED)
# ────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_QUEUE_NAME=redis-queue
REDIS_PASSWORD=             # Optional — leave empty for no auth
REDIS_TLS=false             # Set to true to use rediss:// (TLS)
# Sentinel — comma-separated "host:port" pairs; when set REDIS_HOST/PORT are ignored
REDIS_SENTINEL_HOSTS=       # e.g. sentinel1:26379,sentinel2:26379
REDIS_SENTINEL_SERVICE_NAME=mymaster

# ────────────────────────────────────────────────────────────────────────────
# Object storage  (REQUIRED — choose MinIO or S3)
# ────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_ENDPOINT_URL=http://localhost:9000
AWS_DEFAULT_REGION=us-east-1
MINIO_BUCKET_NAME=test
MINIO_END_POINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
S3_AVAILABLE=False
MINIO_AVAILABLE=True

# ────────────────────────────────────────────────────────────────────────────
# API security  (REQUIRED in production)
# ────────────────────────────────────────────────────────────────────────────
# Values: keycloak | full-access (dev, no auth) | dev (static dev tokens)
VERIFY_TOKEN_MODEL=keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=your-client-id
KEYCLOAK_CLIENT_SECRET=secret

# ────────────────────────────────────────────────────────────────────────────
# OpenWebUI external document loader  (optional)
# ────────────────────────────────────────────────────────────────────────────
# Exposes PUT /api/process, compatible with OpenWebUI's CONTENT_EXTRACTION_ENGINE=external.
# Configure in OpenWebUI: EXTERNAL_DOCUMENT_LOADER_URL=<this API base URL>/api
#                          EXTERNAL_DOCUMENT_LOADER_API_KEY=<value below>
# If unset, /process is left unauthenticated — always set this in production.
EXTERNAL_DOCUMENT_LOADER_API_KEY=
# How often (s) the request polls the task until it completes, and the max total wait before a 504.
EXTERNAL_LOADER_POLL_INTERVAL_SECONDS=2
EXTERNAL_LOADER_MAX_WAIT_SECONDS=600

# ────────────────────────────────────────────────────────────────────────────
# OCR service  (optional — default: external OCR API)
# ────────────────────────────────────────────────────────────────────────────
# Set to "LLM" to use the VLM-based OCR instead of the external API
OCR_SERVICE_LLM=
OCR_BACKEND_URL=https://mirai-ocr-staging.sdid-app.cpin.numerique-interieur.com/

# ────────────────────────────────────────────────────────────────────────────
# Worker / Celery  (optional)
# ────────────────────────────────────────────────────────────────────────────
CELERY_APP_NAME=default
MAX_CONCURRENCY_LLM_CALL=5

# ────────────────────────────────────────────────────────────────────────────
# Caches & temp files  (optional)
# ────────────────────────────────────────────────────────────────────────────
CACHE_FOLDER=/app/.cache/url
PYPANDOC_PANDOC_FOLDER=      # Override pandoc binary location (auto-detected if empty)

# ────────────────────────────────────────────────────────────────────────────
# Observability  (optional)
# ────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development      # development | production | testing
SENTRY_API_DSN=
SENTRY_WORKER_DSN=
SEND_DEFAULT_PII=false
# Langfuse (optionnel — désactivé si LANGFUSE_PUBLIC_KEY est vide)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=local
